{
  "name": "dj-sort",
  "version": "0.1.0",
  "description": "Organizes audio files into DJ-friendly subfolders by BPM, genre, and Discogs metadata",
  "main": "dist/index.js",
  "bin": {
    "dj-sort": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "pkg dist/index.js --targets node20-win-x64,node20-macos-arm64,node20-linux-x64 --out-path builds",
    "bundle:win": "pkg dist/index.js --targets node20-win-x64 --output builds/dj-sort-win.exe",
    "bundle:personal": "pkg dist/index.js --targets node20-win-x64 --output builds/dj-sort-personal.exe",
    "dev": "ts-node src/index.ts"
  },
  "pkg": {
    "scripts": [
      "node_modules/node-web-audio-api/index.cjs",
      "node_modules/node-web-audio-api/load-native.cjs"
    ],
    "assets": [
      "node_modules/node-web-audio-api/prebuilds/**/*",
      "node_modules/node-web-audio-api/**/*.node"
    ]
  },
  "dependencies": {
    "commander": "^12.1.0",
    "music-metadata": "^7.14.0",
    "node-web-audio-api": "^0.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@yao-pkg/pkg": "^6.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
